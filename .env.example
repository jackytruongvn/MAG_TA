# ============================================================
# HR TA Onboarding Input Portal - environment configuration
# Copy to .env and fill in the values. NEVER commit .env.
# ============================================================

# ---------- Database ----------
# SQLite for local/dev. For PostgreSQL change prisma/schema.prisma datasource
# provider to "postgresql" and point DATABASE_URL at your Postgres instance
# (host, port, database name, and your own DB_USER / DB_PASSWORD values).
DATABASE_URL="file:./dev.db"

# ---------- NextAuth ----------
# Generate secret:  openssl rand -base64 32   (or any long random string)
NEXTAUTH_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING"
NEXTAUTH_URL="http://localhost:3000"

# ---------- Microsoft Entra ID (Azure AD) SSO ----------
# From Azure Portal > App registrations (see README.md for full steps)
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# Only allow login from these email domains (comma separated, empty = allow all)
ALLOWED_EMAIL_DOMAINS="masterisegroup.com,masterisehomes.com"

# Bootstrap admins (comma separated emails). These are always ADMIN
# regardless of the Roles config, so you can never lock yourself out.
ADMIN_EMAILS="jackytruongvn@gmail.com"

# ---------- DEV auth bypass (local testing WITHOUT Azure) ----------
# Set both to "true" to show a "Dev sign in" form on /login that accepts
# any email (still validated against ALLOWED_EMAIL_DOMAINS if set).
# NEVER enable in production.
AUTH_DEV_MODE="false"
NEXT_PUBLIC_AUTH_DEV_MODE="false"

# ---------- Email sending (Microsoft Graph) ----------
# EMAIL_MODE:
#   log   = do NOT call Graph; print the email to server console and mark SENT (for local dev)
#   graph = send via Microsoft Graph APPLICATION permission (Mail.Send, admin-consented)
#           -> recommended for production, works unattended (scheduler), no password stored
#   ropc  = send via Microsoft Graph DELEGATED permission using the mailbox's own
#           username/password (Resource Owner Password Credentials flow)
#           -> use when your tenant admin granted Mail.Send as Delegated only and
#              cannot grant Application permission. See README.md §3.4b for caveats
#              (breaks if the mailbox has MFA / Conditional Access; Microsoft
#              discourages ROPC long-term).
EMAIL_MODE="log"

# Graph app credentials (can reuse the SSO app registration; see README.md §3.4)
GRAPH_TENANT_ID=""
GRAPH_CLIENT_ID=""
GRAPH_CLIENT_SECRET=""

# System mailbox used as the sender (must exist in the tenant)
GRAPH_SENDER_MAILBOX="hr.support@masterisegroup.com"

# Only needed when EMAIL_MODE="ropc": the mailbox's own password.
# This is a live credential — never commit it, rotate it periodically,
# and restrict where it can be used (e.g. Conditional Access named location
# limited to your server's IP) since a leak is more sensitive than a client secret.
GRAPH_SENDER_PASSWORD=""

# ---------- Scheduler ----------
# Start the in-process node-cron scheduler with the Next.js server
SCHEDULER_ENABLED="true"
